
# ============================================
# AI REAL ESTATE AGENT - ENVIRONMENT VARIABLES
# ============================================

# Groq LLM API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=

# API Configuration
# For local development, use localhost
API_URL=http://localhost:8000

# Port Configuration (for local development)
API_PORT=8000
UI_PORT=8501

# Python Configuration
PYTHONPATH=.

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Model Configuration
MODEL_PATH=ml/best_model.pkl
STATS_PATH=ml/training_stats.json

# LLM Model Selection (optional)
# Available: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768
LLM_MODEL=llama-3.1-8b-instant

# Deployment Flag (local/production)
ENVIRONMENT=local



real-estate-agent/
│
├── app/                          # FastAPI application
│   ├── __init__.py
│   ├── main.py                   # API endpoints (using APIRouter)
│   ├── model_loader.py           # ML model loading & prediction
│   ├── schemas.py                # Pydantic validation schemas
│   ├── utils.py                  # Utility functions
│   └── prompts/                  # LLM prompt templates
│       └── stage1_prompt.py
│
├── llm/                          # LLM integration
│   ├── __init__.py
│   ├── client.py                 # Groq API client
│   ├── feature_extractor.py      # Stage 1: Feature extraction
│   └── explanation_generator.py  # Stage 2: Explanation generation
│
├── ml/                           # Machine Learning
│   ├── __init__.py
│   ├── best_model.pkl            # Trained model (serialized)
│   ├── training_stats.json       # Market context statistics
│   ├── features.py               # Feature definitions
│   ├── preprocess.py             # Preprocessing pipeline
│   ├── train.py                  # Data loading & splitting
│   └── train_models.py           # Model training script
│
├── streamlit_app/                # Streamlit UI
│   └── app.py                    # Frontend application
│
├── data/                         # Dataset
│   └── raw.csv                   # Ames Housing dataset
│
├── notebooks/                    # Jupyter notebooks
│   └── eda_model_comparison.ipynb
│
├── Dockerfile                    # Single container for both services
├── .env.example                  # Environment variable template
├── .gitignore                    # Git ignore rules
├── requirements.txt              # Python dependencies
└── README.md                     # This file


